# Prefer shared DG app Postgres (Railway injects this automatically).
# When set, Prop Model writes pm_* tables into the same database.
DATABASE_URL=

# SQLite fallback path only used when DATABASE_URL is unset (local offline).
DB_PATH=./data/prop-model.db

# Randomized delay between requests (ms)
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=5000

# Season years used in reference-site URLs
NBA_SEASON_YEAR=2026
MLB_SEASON_YEAR=2025

# Daily cron (server local time). Default: 06:30
NBA_CRON=30 6 * * *
MLB_CRON=45 6 * * *

# Headless browser
PLAYWRIGHT_HEADLESS=true

# Optional: limit players scraped per run (0 = all)
NBA_PLAYER_LIMIT=0
MLB_PLAYER_LIMIT=0
