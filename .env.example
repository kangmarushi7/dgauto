DG_EMAIL=your_email_here
DG_PASSWORD=your_password_here
DG_LOGIN_URL=https://www.datagaffer.com/login
DG_GOAL_ZONE_URL=https://www.datagaffer.com/goal_zone
DG_WIN_OUTLOOK_URL=https://www.datagaffer.com/outlooks#win-outlook

# CSS selectors for login form (adjust once after testing)
DG_EMAIL_SELECTOR=input[type='email']
DG_PASSWORD_SELECTOR=input[type='password']
DG_SUBMIT_SELECTOR=button[type='submit']

# App settings
APP_ENV=dev

# API-Football (api-sports.io) — auto-resolve bet results
# Get key: https://dashboard.api-football.com/ → Account → My Access
API_FOOTBALL_KEY=

# Daily + daytime auto-resolve (main / LM / NO / +EV) — times in AUTO_RESOLVE_TIMEZONE
# Runs at AUTO_RESOLVE_TIME plus 10:30, 16:30, 22:30 by default (minute from AUTO_RESOLVE_TIME)
AUTO_RESOLVE_SCHEDULE_ENABLED=true
AUTO_RESOLVE_TIME=04:30
AUTO_RESOLVE_TIMEZONE=Asia/Kolkata
AUTO_RESOLVE_MAX_RUNTIME_SEC=240

# Auto-pull fixtures from DataGaffer every 6h, always including 09:00 IST
FIXTURE_REFRESH_SCHEDULE_ENABLED=true
FIXTURE_REFRESH_INTERVAL_HOURS=6
FIXTURE_REFRESH_ANCHOR_HOUR=9
FIXTURE_REFRESH_TIMEZONE=Asia/Kolkata

# Optional: protect POST /api/cron/auto-resolve when using an external cron service
CRON_SECRET=

# Database (Railway provides this automatically when Postgres service is attached)
DATABASE_URL=

# Prop Model Engine uses the same DATABASE_URL (pm_* tables).
# Optional local SQLite override only when DATABASE_URL is unset:
# PROP_MODEL_DB_PATH=prop-model-engine/data/prop-model.db
PROP_MODEL_DB_PATH=
