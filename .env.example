DG_EMAIL=your_email_here
DG_PASSWORD=your_password_here
DG_LOGIN_URL=https://www.datagaffer.com/login
DG_GOAL_ZONE_URL=https://www.datagaffer.com/goal_zone
DG_WIN_OUTLOOK_URL=https://www.datagaffer.com/outlooks#win-outlook

# CSS selectors for login form (adjust once after testing)
DG_EMAIL_SELECTOR=input[type='email']
DG_PASSWORD_SELECTOR=input[type='password']
DG_SUBMIT_SELECTOR=button[type='submit']

# App settings
APP_ENV=dev

# Database (Railway provides this automatically when Postgres service is attached)
DATABASE_URL=
